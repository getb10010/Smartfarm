# ============================================================================
# SmartFarmer v3 — AI Oracle Environment Template
# Скопируйте этот файл в .env и заполните значения:  cp .env.example .env
# ============================================================================

# ─── 1. Solana Secrets ───
SOLANA_PRIVATE_KEY=Вставьте_ваш_Private_Key_в_Base58_формате

# ─── 2. RPC Provider ───
# Helius (рекомендуется): https://helius.dev/
SOLANA_RPC_URL=https://api.devnet.solana.com
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# ─── 3. Smart Contract ───
PROGRAM_ID=2c4QahhgmCXWFDuPVsa6i7gBYSUn2DGTNPpXZXwjs21n
CONTRACT_PROGRAM_ID=2c4QahhgmCXWFDuPVsa6i7gBYSUn2DGTNPpXZXwjs21n

# ─── 4. Hyperlocal Weather APIs (каскад: MetGIS → Ambee → Open-Meteo) ───
# MetGIS (30м разрешение) — ОСНОВНОЙ. Регистрация: https://www.metgis.com/api-registration/
METGIS_API_KEY=
# Ambee (500м разрешение) — АЛЬТЕРНАТИВНЫЙ. Регистрация: https://www.getambee.com/
AMBEE_API_KEY=
# Open-Meteo (1-11км) — БЕСПЛАТНЫЙ FALLBACK (API ключ не требуется)

# ─── 5. Satellite NDVI APIs (каскад: AgroMonitoring → EOSDA → SentinelHub) ───

# Для $0 Production используйте AgroMonitoring (дается 3000 Га бесплатно)
# Регистрация: https://agromonitoring.com/
AGROMONITORING_API_KEY=

# Регистрация EOSDA: https://eos.com/crop-monitoring/ 
EOSDA_API_KEY=
# SentinelHub (Copernicus): https://www.sentinel-hub.com/
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# ─── 6. AI / LLM (для агрономических рекомендаций) ───
# Groq Cloud (Llama 3.1, бесплатный): https://console.groq.com/
GROQ_API_KEY=
# OpenRouter (резервный): https://openrouter.ai/
OPENROUTER_API_KEY=

# ─── 7. Telegram Notifications ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 8. TEE / Deployment ───
TEE_MODE=local_dev
# PHALA_TEE=1  # Включить при деплое в Phala Network
